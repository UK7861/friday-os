# FRIDAY OS Environment Configuration

# Database (PostgreSQL)
DATABASE_URL=postgresql://friday_user:friday_password@localhost:5432/friday_db

# Graph Memory (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=friday_neo4j_password

# Real-time / Queue (Redis)
REDIS_URL=redis://localhost:6379/0

# LLM Configurations (Replace with your actual keys)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Security
JWT_SECRET=your_super_secret_jwt_key
ADMIN_PASSWORD=friday_admin_pass

# Voice (Optional)
ELEVENLABS_API_KEY=your_elevenlabs_key
